{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aegis-fund-os",
  "main": ".output/server/index.mjs",
  "assets": {
    "binding": "ASSETS",
    "directory": ".output/public"
  },
  "compatibility_date": "2026-07-16",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  }
}
