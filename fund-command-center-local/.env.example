# Example local configuration. Copy this file to .env.local and replace only
# the placeholders there. Never commit .env.local or any real credential.

# Binance Spot Testnet only. Create an HMAC key at https://testnet.binance.vision/
BINANCE_TESTNET_API_KEY=replace_with_testnet_api_key
BINANCE_TESTNET_API_SECRET=replace_with_testnet_api_secret
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision

# Hyperliquid Testnet public Info API. Wallet addresses are public and optional.
HYPERLIQUID_TESTNET_INFO_URL=https://api.hyperliquid-testnet.xyz/info
HYPERLIQUID_TESTNET_WALLET_ADDRESS=

# Bybit Testnet only.
BYBIT_TESTNET_API_KEY=replace_with_testnet_api_key
BYBIT_TESTNET_API_SECRET=replace_with_testnet_api_secret
BYBIT_TESTNET_BASE_URL=https://api-testnet.bybit.com

# Optional local read-only operations snapshot.
AEGIS_OPERATIONS_SNAPSHOT_PATH=./results/operations_snapshot.json

# Optional server-only Loop Engineering lineage snapshot.
AEGIS_LOOP_SNAPSHOT_PATH=../results/loop_snapshot.json
