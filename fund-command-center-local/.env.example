# Binance Spot Testnet only. Create keys at https://testnet.binance.vision/
# Keep trade and withdrawal permissions disabled whenever the Testnet UI allows it.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision

# Hyperliquid Testnet public Info API. A Testnet wallet address is public and optional;
# it enables read-only positions and open-order counts. No wallet private key is used.
HYPERLIQUID_TESTNET_INFO_URL=https://api.hyperliquid-testnet.xyz/info
HYPERLIQUID_TESTNET_WALLET_ADDRESS=

# Bybit Testnet only. Create keys at https://testnet.bybit.com/
BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_API_SECRET=
BYBIT_TESTNET_BASE_URL=https://api-testnet.bybit.com
AEGIS_OPERATIONS_SNAPSHOT_PATH=./results/operations_snapshot.json
